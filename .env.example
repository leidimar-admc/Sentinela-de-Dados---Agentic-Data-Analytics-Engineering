# Modo do LLM:
#   offline -> deterministico, roda o agente inteiro sem chave nem rede (CI/demo)
#   live    -> chama o Claude (tool-calling + saida estruturada)
LLM_MODE=offline

# FinOps: modelo barato para tarefas simples, modelo forte para raciocinio dificil
LLM_MODEL_FAST=claude-haiku-4-5
LLM_MODEL_SMART=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Guardrails do agente
AGENT_MAX_STEPS=12
AGENT_MAX_USD=0.50

# Entrega de alertas (opcional; cai para console se vazio)
SLACK_WEBHOOK_URL=

# Observabilidade (opcional): grava o trace de cada execucao em JSON
AGENT_TRACE_FILE=
